# Representative residual block.
# Purpose: tests a skip branch joining the main branch under exact timing.
op input_read memory 1 slices=-44..-1,1..44
op conv1 compute 3 slices=-46,46
op batch_norm1 compute 2 slices=0
op relu1 compute 1 slices=0
op conv2 compute 3 slices=-46,46
op batch_norm2 compute 2 slices=0

op skip_projection compute 19 slices=46
op residual_add compute 1 slices=0
op relu_out compute 1 slices=0
op output_write memory 1 slices=-44..-1,1..44

edge input_read conv1
edge conv1 batch_norm1
edge batch_norm1 relu1
edge relu1 conv2
edge conv2 batch_norm2
edge input_read skip_projection
edge batch_norm2 residual_add
edge skip_projection residual_add
edge residual_add relu_out
edge relu_out output_write
